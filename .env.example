# NeuVox 语音服务 - 环境变量配置模板

# ========================
# DeepSeek API 配置 (LLM - 主选)
# ========================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# ========================
# MiMo TTS API 配置 (主选)
# ========================
MIMO_TTS_API_KEY=your_mimo_tts_api_key_here
MIMO_TTS_API_URL=https://api.minimax.chat/v1/t2a_v2
MIMO_TTS_MODEL=mimo-v2.5-tts

# ========================
# MiniMax API 配置 (备份 LLM + TTS)
# ========================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# ========================
# 和风天气 API 配置
# ========================
QWEATHER_API_KEY=your_qweather_api_key_here

# ========================
# Coze 工作流配置
# ========================
COZE_API_KEY=your_coze_api_key_here
COZE_WORKFLOW_KNOWLEDGE_QA=your_knowledge_qa_workflow_id
COZE_WORKFLOW_GENERAL_CHAT=your_general_chat_workflow_id

# ========================
# 服务器配置
# ========================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ========================
# 数据库配置
# ========================
# SQLite (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./data/neuvox.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+asyncpg://neuvox:password@localhost:5432/neuvox
POSTGRES_PASSWORD=neuvox123

# ========================
# Redis 配置
# ========================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ========================
# ChromaDB 配置
# ========================
CHROMA_HOST=localhost
CHROMA_PORT=8000
